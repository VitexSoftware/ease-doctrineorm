#!/usr/bin/make -f

#dpkg-parsechangelog | sed -n 's/^Version: //p'

%:
	dh $@ --with phpcomposer

override_dh_clean:
	rm -rf debian/test/vendor
	dh_clean

#override_dh_prep:
#	mkdir -p docs
#	rm -rf docs/*
#	phpdoc -d src --defaultpackagename=MainPackage
#	mv .phpdoc/build/* docs
#	dh_prep

override_dh_test:
	composer --working-dir=debian/test update
	phpunit --bootstrap debian/test/Bootstrap.php --configuration phpunit.xml tests/
	dh_test

override_dh_install:
	dh_install
	jq '.version = "'`dpkg-parsechangelog | sed -n 's/^Version: //p'| sed 's/~.*//' `'"'  debian/composer.json |sponge debian/php-vitexsoftware-ease-doctrineorm/usr/share/php/EaseDoctrine/composer.json
	phpab --output debian/php-vitexsoftware-ease-doctrineorm/usr/share/php/EaseDoctrine/autoload.php \
		--basedir debian/php-vitexsoftware-ease-doctrineorm/usr/share/php/EaseDoctrine \
		--tolerant \
		debian/php-vitexsoftware-ease-doctrineorm/usr/share/php/EaseDoctrine
	install -m0755 -d debian/php-vitexsoftware-ease-doctrineorm/usr/share/pkg-php-tools/autoloaders
	echo 'vitexsoftware ease-doctrine EaseDoctrine/autoload.php' > debian/php-vitexsoftware-ease-doctrineorm/usr/share/pkg-php-tools/autoloaders/php-vitexsoftware-ease-doctrineorm
